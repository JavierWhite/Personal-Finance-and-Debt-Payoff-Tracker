{
  "info": {
    "name": "Personal Finance Tracker, Checkpoint 2 Security",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman demo collection for the Personal Finance and Debt Payoff Tracker. Includes registration, JWT authentication, authorization checks, password reminder/reset, and tracker workflows."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "userBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "debtBaseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "savingsBaseUrl",
      "value": "http://localhost:8083"
    },
    {
      "key": "retirementBaseUrl",
      "value": "http://localhost:8084"
    },
    {
      "key": "analyticsBaseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "registeredUserId",
      "value": ""
    },
    {
      "key": "debtId",
      "value": ""
    },
    {
      "key": "savingsGoalId",
      "value": ""
    },
    {
      "key": "retirementAccountId",
      "value": ""
    },
    {
      "key": "snapshotId",
      "value": ""
    },
    {
      "key": "incomeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "00 Authentication and Authorization",
      "item": [
        {
          "name": "Login regular user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{userBaseUrl}}/auth/login",
              "host": [
                "{{userBaseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"javier\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logged in', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('userId', body.id);",
                  "pm.collectionVariables.set('authToken', body.token);",
                  "pm.test('JWT token returned', function () { pm.expect(body.token).to.be.a('string').and.not.empty; });",
                  "pm.test('Role is USER', function () { pm.expect(body.role).to.eql('USER'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register demo user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{userBaseUrl}}/auth/register",
              "host": [
                "{{userBaseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"securitydemo{{$timestamp}}\",\n  \"email\": \"securitydemo{{$timestamp}}@example.com\",\n  \"firstName\": \"Security\",\n  \"lastName\": \"Demo\",\n  \"password\": \"Password123!\",\n  \"active\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Registered', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('registeredUserId', body.id);",
                  "pm.test('Registration returned token', function () { pm.expect(body.token).to.be.a('string').and.not.empty; });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Password reminder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
