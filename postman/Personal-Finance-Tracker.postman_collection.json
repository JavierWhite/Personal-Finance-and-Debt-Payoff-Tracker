              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"javier@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reminder token created', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('resetToken', body.resetToken);",
                  "pm.test('Reset token exists', function () { pm.expect(body.resetToken).to.be.a('string').and.not.empty; });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Password reset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{userBaseUrl}}/auth/password-reset",
              "host": [
                "{{userBaseUrl}}"
              ],
              "path": [
                "auth",
                "password-reset"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Password reset completed', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('userId', body.id);",
                  "pm.collectionVariables.set('authToken', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "User blocked from admin user list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userBaseUrl}}/users",
              "host": [
                "{{userBaseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Regular user is forbidden', function () { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{userBaseUrl}}/auth/login",
              "host": [
                "{{userBaseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin logged in', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', body.token);",
                  "pm.test('Role is ADMIN', function () { pm.expect(body.role).to.eql('ADMIN'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin can list users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userBaseUrl}}/users",
              "host": [
                "{{userBaseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin can view users', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
